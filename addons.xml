<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="plugin.video.classysbase"
         name="Classy's Base"
         version="1.0.0"
         provider-name="Classy">
    <requires>
      <import addon="xbmc.python" version="3.0.0"/>
      <import addon="script.module.requests"/>
      <import addon="script.module.resolveurl"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
      <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
      <reuselanguageinvoker>false</reuselanguageinvoker>
      <summary lang="en">Classy's Base — curated media, clean code</summary>
      <description lang="en">Clean, fast access to Chains' curated media playlists.</description>
      <platform>all</platform>
      <assets>
        <icon>icon.png</icon>
        <fanart>fanart.jpg</fanart>
      </assets>
    </extension>
  </addon>
  <addon id="repository.classymouse"
         name="Classymouse Repository"
         version="1.0.0"
         provider-name="Classy">
    <requires>
      <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Classymouse Repository">
      <info compressed="false">https://classymouse.github.io/repository.classymouse/addons.xml</info>
      <checksum>https://classymouse.github.io/repository.classymouse/addons.xml.md5</checksum>
      <datadir zip="true">https://classymouse.github.io/repository.classymouse/</datadir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en">Classymouse Repository</summary>
      <description lang="en">Addons by Classymouse. First addon: Classy's Base.</description>
      <platform>all</platform>
    </extension>
  </addon>
</addons>
